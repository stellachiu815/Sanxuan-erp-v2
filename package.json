{
  "name": "sanxuan-erp",
  "version": "12.1.0",
  "private": true,
  "description": "台北三玄宮行政系統 ERP",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start -p ${PORT:-3000}",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "test:purification": "tsx --test tests/*.test.ts",
    "backup:before-update": "tsx scripts/preDeployBackup.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "html2canvas": "^1.4.1",
    "jspdf": "^2.5.2",
    "lunar-javascript": "*",
    "next": "^15.1.0",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
